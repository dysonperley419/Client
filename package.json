{
  "name": "flicker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "eslint": "npx eslint .",
    "eslint:fix": "npx eslint --fix .",
    "lint": "run-s -c eslint stylelint prettier",
    "lint:fix": "run-s -c eslint:fix stylelint:fix prettier",
    "prepare": "husky",
    "prettier": "npx prettier . --write",
    "preview": "vite preview",
    "stylelint": "npx stylelint -o \"stylelint.log\" \"**/*.css\"",
    "stylelint:fix": "npx stylelint -o \"stylelint.log\" --fix \"**/*.css\""
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "shiki": "^4.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.3",
    "@eslint/json": "^1.0.1",
    "@eslint/markdown": "^7.5.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript-eslint": "^8.56.1",
    "vite": "npm:rolldown-vite@latest"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
